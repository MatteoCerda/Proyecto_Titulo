# --- Etapa 1: Build Angular con pnpm + Nx ---
FROM node:20-bullseye AS builder
RUN corepack enable
WORKDIR /workspace

# Manifiestos del monorepo (raÃ­z)
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml nx.json tsconfig.base.json ./

# CÃ³digo del frontend
COPY web/ web/

# Instalar deps (monorepo)
RUN pnpm install --no-frozen-lockfile

# Build de la app web (producciÃ³n)
RUN pnpm nx build web

# Normalizar carpeta de salida (dist/apps/web o dist/web)
RUN mkdir -p /webdist && \
    if [ -d "dist/apps/web" ]; then cp -r dist/apps/web/* /webdist/; \
    else cp -r dist/web/* /webdist/; fi

# --- Etapa 2: Nginx sirviendo estÃ¡ticos y haciendo proxy a /api ---
FROM nginx:1.27-alpine AS runtime
WORKDIR /usr/share/nginx/html

# Limpiar html por defecto
RUN rm -rf ./*

# Copiar build Angular
COPY --from=builder /webdist/ ./

# Config nginx con proxy /api -> api:3000
COPY web/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
